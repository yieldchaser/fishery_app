        "cheerio": "^1.2.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^7.3.1",
        "helmet": "^7.1.0",
        "node-cron": "^4.2.1",
        "node-fetch": "^2.7.0",
        "pg": "^8.12.0",
        "puppeteer": "^24.38.0",
        "redis": "^4.6.14",
        "uuid": "^7.0.3",
        "winston": "^3.13.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.14.2",
        "@types/pg": "^8.11.6",
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.3",
